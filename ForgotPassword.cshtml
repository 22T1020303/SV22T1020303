@model V22T1020381.Admin.Models.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Quên mật khẩu</title>
    <link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg, #eff6ff, #f8fafc);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
        }

        .box {
            width: 100%;
            max-width: 500px;
            background: #fff;
            border-radius: 24px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(15, 23, 42, .12);
        }

        .title {
            font-size: 30px;
            font-weight: 800;
            color: #0f172a;
            margin-bottom: 8px;
        }

        .sub {
            color: #64748b;
            line-height: 1.7;
            margin-bottom: 24px;
        }

        .form-label {
            font-weight: 700;
            margin-bottom: 8px;
            color: #1e293b;
        }

        .form-control {
            height: 50px;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
        }

            .form-control:focus {
                border-color: #93c5fd;
                box-shadow: 0 0 0 4px rgba(37, 99, 235, .12);
            }

        .field-validation-error {
            color: #dc2626;
            font-size: 13px;
            margin-top: 6px;
            display: block;
        }

        .validation-summary-errors {
            background: #fef2f2;
            color: #b91c1c;
            border: 1px solid #fecaca;
            border-radius: 14px;
            padding: 12px 14px;
            margin-bottom: 16px;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 18px;
            }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 24px;
        }

        .btn-main {
            flex: 1;
            height: 50px;
            border: 0;
            border-radius: 14px;
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            color: #fff;
            font-weight: 700;
        }

        .btn-light2 {
            flex: 1;
            height: 50px;
            border-radius: 14px;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #334155;
            font-weight: 700;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }
    </style>
</head>
<body>
    <div class="box">
        <div class="title">Quên mật khẩu</div>
        <div class="sub">Nhập email nhân viên để gửi yêu cầu hỗ trợ đặt lại mật khẩu.</div>

        <form method="post" action="~/Account/ForgotPassword">
            <div asp-validation-summary="All"></div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="vd: leduchung@mycompany.com" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="actions">
                <a href="~/Account/Login" class="btn-light2">Quay lại</a>
                <button type="submit" class="btn-main">Gửi yêu cầu</button>
            </div>
        </form>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>