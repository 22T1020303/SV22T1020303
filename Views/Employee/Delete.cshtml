@using LiteCommerce.Models.HR
@using SV22T1020303.Admin
@using SV22T1020303.Admin.Models
@model Employee

@{
    ViewBag.Title = "Xóa nhân viên";
}

@section PageToolBar {
    @if (ViewBag.CanDelete)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash me-1"></i>
            Xóa
        </button>
    }

    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @(ViewBag.CanDelete ? "Xác nhận xóa nhân viên" : "Thông báo")
                </h5>
            </div>

            <div class="card-body">
                <form id="formDelete" method="post" action="~/Employee/Delete/@Model.EmployeeID">
                    @if (ViewBag.CanDelete)
                    {
                        <div class="alert alert-warning d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Bạn có chắc chắn muốn xóa nhân viên sau không?
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-info d-flex align-items-center">
                            <i class="bi bi-info-circle me-2"></i>
                            Không thể xóa nhân viên này vì đã có dữ liệu liên quan.
                        </div>
                    }

                    <div class="row">
                        <div class="col-md-2 text-start">
                            <img src="~/images/employees/nophoto.png"
                                 class="img-thumbnail mb-2"
                                 style="width: 100%;"
                                 alt="Ảnh nhân viên" />
                        </div>

                        <div class="col-md-10">
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Họ và tên</dt>
                                <dd class="col-sm-9">@Model.FullName</dd>

                                <dt class="col-sm-3">Ngày sinh</dt>
                                <dd class="col-sm-9">@(Model.BirthDate?.ToString("dd/MM/yyyy"))</dd>

                                <dt class="col-sm-3">Điện thoại</dt>
                                <dd class="col-sm-9">@Model.Phone</dd>

                                <dt class="col-sm-3">Email</dt>
                                <dd class="col-sm-9">@Model.Email</dd>

                                <dt class="col-sm-3">Địa chỉ</dt>
                                <dd class="col-sm-9">@Model.Address</dd>

                                <dt class="col-sm-3">Trạng thái</dt>
                                <dd class="col-sm-9">
                                    @if (Model.IsWorking == true)
                                    {
                                        <span class="badge bg-success">Đang làm việc</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã nghỉ việc</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>