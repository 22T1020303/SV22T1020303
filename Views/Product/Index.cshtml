@model LiteCommerce.Models.Catalog.ProductSearchInput

@{
    ViewBag.Title = "Quản lý mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-search me-2"></i>
            Tìm kiếm mặt hàng
        </h5>
    </div>

    <div class="card-body">
        <form id="formSearch" action="~/Product/Search" method="get">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select"
                            asp-for="CategoryID"
                            asp-items="ViewBag.Categories">
                    </select>
                </div>

                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select"
                            asp-for="SupplierID"
                            asp-items="ViewBag.Suppliers">
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input asp-for="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input asp-for="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input asp-for="SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..."
                               autofocus />
                        <button class="btn btn-info d-flex align-items-center" type="submit">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            doSearch(1);

            const formSearch = document.getElementById("formSearch");
            formSearch.addEventListener("submit", function (e) {
                e.preventDefault();
                doSearch(1);
            });
        });

        function doSearch(page) {
            const form = document.getElementById("formSearch");
            const formData = new FormData(form);
            formData.set("Page", page);

            const params = new URLSearchParams();
            for (const pair of formData.entries()) {
                params.append(pair[0], pair[1]);
            }

            fetch(form.action + "?" + params.toString(), {
                method: "GET"
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById("searchResult").innerHTML = html;
            })
            .catch(error => {
                console.error(error);
            });
        }
    </script>
}