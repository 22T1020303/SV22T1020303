@model IEnumerable<LiteCommerce.Models.Catalog.ProductPhoto>

@{
    Layout = null;
    var productId = ViewBag.ProductID ?? 0;
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info mt-3">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h5 id="photos" class="card-title mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h5>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@productId">
                            <i class="bi bi-plus-circle me-1"></i>
                            Bổ sung
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0 align-middle">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px" class="text-center">Hiển thị</th>
                            <th style="width:100px" class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="~/images/products/@(string.IsNullOrWhiteSpace(item.Photo) ? "nophoto.png" : item.Photo)"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    </td>
                                    <td>@item.Description</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@productId?photoId=@item.PhotoID">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@productId?photoId=@item.PhotoID">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            @for (int i = 1; i <= 5; i++)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="~/images/products/demo.png"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    </td>
                                    <td>Ảnh mặt trước sản phẩm</td>
                                    <td class="text-center">@i</td>
                                    <td class="text-center">
                                        <span class="badge bg-success">Hiện</span>
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/@productId?photoId=1">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/@productId?photoId=1">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>