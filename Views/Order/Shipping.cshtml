@model OrderViewInfo

@{
    Layout = null;
}

<form id="formShipping" onsubmit="shippingOrder(event, @Model.OrderID)">
    <div class="modal-header text-bg-info">
        <strong class="modal-title">
            Chọn người giao hàng
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="alert alert-info d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Chọn người giao hàng cho đơn hàng này
        </div>

        <dl class="row mb-3">
            <dt class="col-sm-4">Mã đơn hàng</dt>
            <dd class="col-sm-8">@Model.OrderID</dd>

            <dt class="col-sm-4">Khách hàng</dt>
            <dd class="col-sm-8">@Model.CustomerName</dd>
        </dl>

        <div class="mb-3">
            <label class="form-label">Người giao hàng</label>
            <select id="shipperID" class="form-select">
                <option value="0">-- Chọn người giao hàng --</option>
                <option value="1">Giao hàng Tiết kiệm</option>
                <option value="2">Tín Thành</option>
                <option value="3">Viettel Express</option>
            </select>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bicycle"></i> Giao hàng
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>