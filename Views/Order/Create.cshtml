@model ProductSearchInput

@{
    ViewBag.Title = "Lập đơn hàng";
    var provinces = await SelectListHelper.ProvincesAsync();
}

<div class="row">
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <form id="formSearch" class="mb-3"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <input type="hidden" asp-for="PageSize" />
                    <div class="input-group">
                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm"
                               autofocus />
                        <button type="submit" class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i> Tìm
                        </button>
                    </div>
                </form>

                <div id="searchResult"></div>
            </div>
        </div>
    </div>

    <div class="col-8">
        <div class="row">
            <div class="col-12" id="cartResult"></div>
        </div>

        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form onsubmit="createOrder(event,this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerID" asp-items="ViewBag.Customers">
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="province" asp-items="provinces">
                                        <option value="">-- Chọn Tỉnh/thành giao hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById('formSearch'), @Model.Page);
            showCart();
        });

        async function paginationSearch(event, form, page = 1) {
            if (event) event.preventDefault();

            const formData = new FormData(form);
            formData.set('Page', page);

            try {
                const url = new URL(form.action, window.location.origin);
                for (const [key, value] of formData.entries()) {
                    url.searchParams.set(key, value);
                }

                const response = await fetch(url, {
                    method: 'GET'
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const html = await response.text();
                const targetId = form.getAttribute('data-target');
                if (targetId) {
                    document.getElementById(targetId).innerHTML = html;
                }
            } catch (error) {
                console.error(error);
                alert('Lỗi khi tải danh sách sản phẩm');
            }
        }

        async function showCart() {
            try {
                const response = await fetch('/Order/ShowCart', {
                    method: 'GET'
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const html = await response.text();
                document.getElementById('cartResult').innerHTML = html;
            } catch (error) {
                console.error(error);
                document.getElementById('cartResult').innerHTML = '<p>Lỗi khi tải giỏ hàng</p>';
            }
        }

        async function addCartItem(event, form) {
            event.preventDefault();

            try {
                const formData = new FormData(form);

                const response = await fetch('/Order/AddCartItem', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const result = await response.json();

                if (result.code === 0) {
                    alert(result.message);
                } else {
                    showCart();
                }
            } catch (error) {
                console.error(error);
                alert('Có lỗi xảy ra');
            }
        }

        async function deleteCartItem(productID) {
            try {
                const response = await fetch(`/Order/DeleteCartItemConfirmed?productId=${productID}`, {
                    method: 'POST'
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const modalEl = document.getElementById('dialogModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                if (modal) modal.hide();

                showCart();
            } catch (error) {
                console.error(error);
                alert('Không thể xóa sản phẩm');
            }
        }

        async function clearCart() {
            try {
                const response = await fetch('/Order/ClearCartConfirmed', {
                    method: 'POST'
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const modalEl = document.getElementById('dialogModal');
                const modal = bootstrap.Modal.getInstance(modalEl);
                if (modal) modal.hide();

                showCart();
            } catch (error) {
                console.error(error);
                alert('Không thể xóa giỏ hàng');
            }
        }

        async function updateCartItem(event, form) {
            event.preventDefault();

            try {
                const formData = new FormData(form);

                const response = await fetch('/Order/UpdateCartItem', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const result = await response.json();

                if (result.code === 0) {
                    alert(result.message);
                } else {
                    const modalEl = document.getElementById('dialogModal');
                    const modal = bootstrap.Modal.getInstance(modalEl) || new bootstrap.Modal(modalEl);
                    modal.hide();

                    showCart();
                }
            } catch (error) {
                console.error(error);
                alert('Có lỗi xảy ra');
            }
        }

        async function createOrder(event, form) {
            event.preventDefault();

            try {
                const formData = new FormData(form);

                const response = await fetch('/Order/CreateOrder', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    throw new Error('Lỗi khi gọi API');
                }

                const result = await response.json();

                if (result.code === 0) {
                    alert(result.message || 'Có lỗi xảy ra khi tạo đơn hàng');
                } else {
                    window.location.href = `/Order/Detail/${result.code}`;
                }
            } catch (error) {
                console.error(error);
                alert('Có lỗi xảy ra khi tạo đơn hàng');
            }
        }
    </script>
}