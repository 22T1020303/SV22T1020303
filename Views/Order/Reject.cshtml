@model OrderViewInfo

@{
    Layout = null;
}

<form id="formReject" onsubmit="rejectOrder(event, @Model.OrderID)">
    <div class="modal-header text-bg-danger">
        <strong class="modal-title">
            Xác nhận từ chối đơn hàng
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có thực sự muốn từ chối đơn hàng này không?
        </div>

        <dl class="row mb-3">
            <dt class="col-sm-4">Mã đơn hàng</dt>
            <dd class="col-sm-8">@Model.OrderID</dd>

            <dt class="col-sm-4">Khách hàng</dt>
            <dd class="col-sm-8">@Model.CustomerName</dd>
        </dl>

        <div class="mb-3">
            <label class="form-label">Lý do từ chối</label>
            <textarea id="rejectReason"
                      class="form-control"
                      rows="3"
                      placeholder="Nhập lý do từ chối..."></textarea>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-x-circle"></i> Từ chối
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>